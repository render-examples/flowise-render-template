# Local-dev only. Render sets these for you on deploy via render.yaml.
# Copy to .env if you want to run the flowiseai/flowise image locally.

PORT=3000

DATABASE_TYPE=sqlite
DATABASE_PATH=./.flowise

SECRETKEY_STORAGE_TYPE=local
SECRETKEY_PATH=./.flowise

LOG_PATH=./.flowise/logs
LOG_LEVEL=info

STORAGE_TYPE=local
BLOB_STORAGE_PATH=./.flowise/storage

NUMBER_OF_PROXIES=1
TRUST_PROXY=true
DISABLE_FLOWISE_TELEMETRY=true
